LazyIde = (
    | browser workspace debugger |

    initialize = (
        browser := Browser new initialize.
        workspace := Workspace new initialize.
        debugger := Debugger new.
    )

    run = (
        self initialize.
    )

    renderFrameOn: nativeContextPtr = (
        | ctx |
        ctx := EguiContext new.
        ctx handle: nativeContextPtr.

        ctx window: 'System Browser' do: [:winUi |
            browser renderOn: winUi.
        ].

        ctx window: 'Workspace' do: [:winUi |
            workspace renderOn: winUi.
        ].

        ctx window: 'Debugger' do: [:winUi |
            debugger renderOn: winUi.
        ].
    )
)
