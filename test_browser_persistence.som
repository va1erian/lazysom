TestClass = ( | a b c | foo = ( ^ a ) )

TestBrowserPersistence = (
    run = (
        | browser cls src res |
        browser := Browser new initialize.
        cls := TestClass.

        system printString: 'Reconstructing class source for TestClass...'.
        system printNewline.
        src := browser reconstructClassSource: cls.

        browser saveClass: cls.

        res := system readText: 'User/TestClass.som'.
        system printString: 'Read saved file... '.
        system printNewline.
        system printString: res.
        system printNewline.
    )
)
